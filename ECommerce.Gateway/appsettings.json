{
  "ReverseProxy": {
    "Routes": {
      "products-route": {
        "ClusterId": "products-cluster",
        "Match": { "Path": "/api/products/{**catch-all}" }
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      // --- TUS TAREAS: AGREGAR ESTAS RUTAS ---
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": { "Path": "/api/cart/{**catch-all}" }
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" }
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      }
    },
    "Clusters": {
      "products-cluster": {
        "Destinations": { "destination1": { "Address": "https://localhost:7001" } }
      },
      "users-cluster": {
        "Destinations": { "destination1": { "Address": "https://localhost:7002" } }
      },
      // --- TUS TAREAS: AGREGAR ESTOS CLUSTERS (Alineá los puertos a tu config) ---
      "cart-cluster": {
        "Destinations": { "destination1": { "Address": "https://localhost:7003" } }
      },
      "orders-cluster": {
        "Destinations": { "destination1": { "Address": "https://localhost:7004" } }
      },
      "notifications-cluster": {
        "Destinations": { "destination1": { "Address": "https://localhost:7005" } }
      }
    }
  }
}
